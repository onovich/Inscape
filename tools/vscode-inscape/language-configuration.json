{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "{",
      "}"
    ]
  ],
  "autoClosingPairs": [
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "{",
      "}"
    ],
    [
      "\"",
      "\""
    ]
  ],
  "surroundingPairs": [
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "{",
      "}"
    ],
    [
      "\"",
      "\""
    ]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*\\?\\s+.*$",
    "decreaseIndentPattern": "^\\s*::\\s+[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)*\\s*$"
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^`~!@#$%^&*()+=[\\]{}\\\\|;:'\\\",<>/?\\s]+)"
}
