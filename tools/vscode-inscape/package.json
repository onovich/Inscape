{
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/inscape"
  },
  "name": "inscape-vscode",
  "displayName": "Inscape DSL",
  "description": "Syntax highlighting and authoring helpers for Inscape narrative scripts.",
  "version": "0.1.0",
  "publisher": "onovich",
  "license": "UNLICENSED",
  "main": "./extension.js",
  "scripts": {
    "package:vsix": "vsce package --out inscape-vscode.vsix",
    "install:vsix": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/rebuild-and-install.ps1",
    "rebuild:vsix": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/rebuild-and-install.ps1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "inscape",
        "aliases": [
          "Inscape",
          "inscape"
        ],
        "extensions": [
          ".inscape"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "inscape",
        "scopeName": "source.inscape",
        "path": "./syntaxes/inscape.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "inscape",
        "path": "./snippets/inscape.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "inscape.openPreview",
        "title": "Inscape: Open Preview",
        "category": "Inscape"
      },
      {
        "command": "inscape.togglePreview",
        "title": "Inscape: Toggle Preview",
        "category": "Inscape"
      },
      {
        "command": "inscape.extractLocalization",
        "title": "Inscape: Export Localization CSV",
        "category": "Inscape"
      },
      {
        "command": "inscape.updateLocalization",
        "title": "Inscape: Update Localization CSV From Previous Table",
        "category": "Inscape"
      },
      {
        "command": "inscape.showHostSchemaCapabilities",
        "title": "Inscape: Show Host Schema Capabilities",
        "category": "Inscape"
      }
    ],
    "customEditors": [
      {
        "viewType": "inscape.preview",
        "displayName": "Inscape Preview",
        "selector": [
          {
            "filenamePattern": "*.inscape"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "inscape.togglePreview",
          "when": "resourceLangId == inscape",
          "group": "navigation@1"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": [
          "inscape.host.schema.json",
          "*.host.schema.json",
          "**/inscape.host.schema.json",
          "**/*.host.schema.json"
        ],
        "url": "./schemas/host-schema.schema.json"
      }
    ],
    "configuration": {
      "title": "Inscape",
      "properties": {
        "inscape.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Enable compiler-backed diagnostics for .inscape files."
        },
        "inscape.diagnostics.debounceMs": {
          "type": "number",
          "default": 450,
          "minimum": 100,
          "scope": "resource",
          "description": "Delay before refreshing diagnostics after document changes."
        },
        "inscape.compiler.command": {
          "type": "string",
          "default": "dotnet",
          "scope": "resource",
          "description": "Command used by the VSCode extension to invoke the Inscape compiler."
        },
        "inscape.compiler.args": {
          "type": "array",
          "default": [
            "run",
            "--project",
            "${workspaceFolder}/src/Inscape.Cli/Inscape.Cli.csproj",
            "--",
            "diagnose-project",
            "${workspaceFolder}",
            "--override",
            "${documentFile}",
            "${file}"
          ],
          "items": {
            "type": "string"
          },
          "scope": "resource",
          "description": "Arguments used to invoke the Inscape compiler. Supported variables: ${workspaceFolder}, ${extensionPath}, ${file}, ${documentFile}."
        }
      }
    }
  }
}
