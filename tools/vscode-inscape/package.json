{
  "name": "inscape-vscode",
  "displayName": "Inscape DSL",
  "description": "Syntax highlighting and authoring helpers for Inscape narrative scripts.",
  "version": "0.1.0",
  "publisher": "onovich",
  "license": "UNLICENSED",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.92.0"
  },
  "activationEvents": [
    "onLanguage:inscape",
    "onCommand:inscape.extractLocalization",
    "onCommand:inscape.updateLocalization"
  ],
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "inscape",
        "aliases": [
          "Inscape",
          "inscape"
        ],
        "extensions": [
          ".inscape"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "inscape",
        "scopeName": "source.inscape",
        "path": "./syntaxes/inscape.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "inscape",
        "path": "./snippets/inscape.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "inscape.extractLocalization",
        "title": "Inscape: Export Localization CSV",
        "category": "Inscape"
      },
      {
        "command": "inscape.updateLocalization",
        "title": "Inscape: Update Localization CSV From Previous Table",
        "category": "Inscape"
      }
    ],
    "configuration": {
      "title": "Inscape",
      "properties": {
        "inscape.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable compiler-backed diagnostics for .inscape files."
        },
        "inscape.diagnostics.debounceMs": {
          "type": "number",
          "default": 450,
          "minimum": 100,
          "description": "Delay before refreshing diagnostics after document changes."
        },
        "inscape.compiler.command": {
          "type": "string",
          "default": "dotnet",
          "description": "Command used by the VSCode extension to invoke the Inscape compiler."
        },
        "inscape.compiler.args": {
          "type": "array",
          "default": [
            "run",
            "--project",
            "${workspaceFolder}/src/Inscape.Cli/Inscape.Cli.csproj",
            "--",
            "diagnose-project",
            "${workspaceFolder}",
            "--override",
            "${documentFile}",
            "${file}"
          ],
          "items": {
            "type": "string"
          },
          "description": "Arguments used to invoke the Inscape compiler. Supported variables: ${workspaceFolder}, ${extensionPath}, ${file}, ${documentFile}."
        }
      }
    }
  }
}
